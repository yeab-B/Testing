    {
      "name": "GET Products List",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Response time\r",
              "pm.test(\"Response time is below 5000ms\", function () {\r",
              "    pm.expect(pm.response.responseTime).to.be.below(5000);\r",
              "});\r",
              "\r",
              "// Content-Type\r",
              "pm.test(\"Content-Type exists\", function () {\r",
              "    pm.expect(pm.response.headers.get(\"Content-Type\")).to.exist;\r",
              "});\r",
              "\r",
              "const response = pm.response.json();\r",
              "\r",
              "// Products not empty\r",
              "pm.test(\"Products list is not empty\", function () {\r",
              "    pm.expect(response.products.length).to.be.above(0);\r",
              "});\r",
              "\r",
              "// JSON Schema\r",
              "const schema = {\r",
              "    type: \"object\",\r",
              "    required: [\"products\"],\r",
              "    properties: {\r",
              "        products: {\r",
              "            type: \"array\",\r",
              "            items: {\r",
              "                type: \"object\",\r",
              "                required: [\"id\", \"name\", \"price\", \"brand\", \"category\"],\r",
              "                properties: {\r",
              "                    id: { type: \"integer\" },\r",
              "                    name: { type: \"string\" },\r",
              "\r",
              "                    // API returns price as string\r",
              "                    price: { type: \"string\" },\r",
              "\r",
              "                    brand: { type: \"string\" },\r",
              "\r",
              "                    // category is object\r",
              "                    category: {\r",
              "                        type: \"object\",\r",
              "                        required: [\"usertype\", \"category\"],\r",
              "                        properties: {\r",
              "                            usertype: {\r",
              "                                type: \"object\",\r",
              "                                properties: {\r",
              "                                    usertype: { type: \"string\" }\r",
              "                                }\r",
              "                            },\r",
              "                            category: { type: \"string\" }\r",
              "                        }\r",
              "                    }\r",
              "                }\r",
              "            }\r",
              "        }\r",
              "    }\r",
              "};\r",
              "\r",
              "pm.test(\"Schema validation\", function () {\r",
              "    pm.response.to.have.jsonSchema(schema);\r",
              "});\r",
              "\r",
              "// No duplicate IDs\r",
              "const ids = response.products.map(p => p.id);\r",
              "const uniqueIds = [...new Set(ids)];\r",
              "\r",
              "pm.test(\"No duplicate IDs\", function () {\r",
              "    pm.expect(ids.length).to.eql(uniqueIds.length);\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://automationexercise.com/api/productsList",
          "protocol": "https",
          "host": [
            "automationexercise",
            "com"
          ],
          "path": [
            "api",
            "productsList"
          ]
        }
      },
