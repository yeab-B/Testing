    {
      "name": "Random Token Generator",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Generate random token\r",
              "const token =\r",
              "    Math.random().toString(36).substring(2);\r",
              "\r",
              "// Save token\r",
              "pm.environment.set(\"randomToken\", token);\r",
              "\r",
              "// Log token\r",
              "console.log(\"Generated Token:\", token);\r",
              "\r",
              "// Add Authorization header\r",
              "pm.request.headers.upsert({\r",
              "    key: \"Authorization\",\r",
              "    value: `Bearer ${token}`\r",
              "});\r",
              "\r",
              "// Add ReqRes API key\r",
              "pm.request.headers.upsert({\r",
              "    key: \"x-api-key\",\r",
              "    value: pm.environment.get(\"apiKey\")\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Status code validation\r",
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "// Response time validation\r",
              "pm.test(\"Response time less than 300ms\", function () {\r",
              "\r",
              "    pm.expect(\r",
              "        pm.response.responseTime\r",
              "    ).to.be.below(300);\r",
              "});\r",
              "\r",
              "// Parse response\r",
              "const response = pm.response.json();\r",
              "\r",
              "// Pagination fields validation\r",
              "pm.test(\"Pagination fields exist\", function () {\r",
              "\r",
              "    pm.expect(response.page).to.exist;\r",
              "\r",
              "    pm.expect(response.per_page).to.exist;\r",
              "\r",
              "    pm.expect(response.total).to.exist;\r",
              "});\r",
              "\r",
              "// Validate user count matches per_page\r",
              "pm.test(\"Users count matches per_page\", function () {\r",
              "\r",
              "    pm.expect(response.data.length)\r",
              "      .to.eql(response.per_page);\r",
              "});\r",
              "\r",
              "// Validate Authorization header exists\r",
              "pm.test(\"Authorization header exists\", function () {\r",
              "\r",
              "    const auth =\r",
              "        pm.request.headers.get(\"Authorization\");\r",
              "\r",
              "    pm.expect(auth).to.include(\"Bearer\");\r",
              "});\r",
              "\r",
              "// Log token\r",
              "console.log(\r",
              "    \"Authorization Header:\",\r",
              "    pm.request.headers.get(\"Authorization\")\r",
              ");\r",
              "\r",
              "console.log(\r",
              "    \"Response Time:\",\r",
              "    pm.response.responseTime\r",
              ");"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
