    {
      "name": "performance",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Get max response time from environment\r",
              "const maxAllowedTime =\r",
              "    pm.environment.get(\"maxResponseTime\") || 500;\r",
              "\r",
              "// Current response time\r",
              "const currentTime = pm.response.responseTime;\r",
              "\r",
              "// Validate response time\r",
              "pm.test(\"Response time is within threshold\", function () {\r",
              "    pm.expect(currentTime).to.be.below(maxAllowedTime);\r",
              "});\r",
              "\r",
              "// Warning if exceeded\r",
              "if (currentTime > maxAllowedTime) {\r",
              "    console.warn(\r",
              "        \"WARNING: Response time exceeded threshold!\"\r",
              "    );\r",
              "}\r",
              "\r",
              "// Get stored response times\r",
              "let responseTimes =\r",
              "    pm.environment.get(\"responseTimes\");\r",
              "\r",
              "responseTimes = responseTimes\r",
              "    ? JSON.parse(responseTimes)\r",
              "    : [];\r",
              "\r",
              "// Add current response time\r",
              "responseTimes.push(currentTime);\r",
              "\r",
              "// Save updated list\r",
              "pm.environment.set(\r",
              "    \"responseTimes\",\r",
              "    JSON.stringify(responseTimes)\r",
              ");\r",
              "\r",
              "// Calculate metrics\r",
              "const minTime = Math.min(...responseTimes);\r",
              "\r",
              "const maxTime = Math.max(...responseTimes);\r",
              "\r",
              "const avgTime =\r",
              "    responseTimes.reduce((a, b) => a + b, 0) /\r",
              "    responseTimes.length;\r",
              "\r",
              "// Store metrics\r",
              "pm.environment.set(\"minTime\", minTime);\r",
              "\r",
              "pm.environment.set(\"maxTime\", maxTime);\r",
              "\r",
              "pm.environment.set(\r",
              "    \"avgTime\",\r",
              "    avgTime.toFixed(2)\r",
              ");\r",
              "\r",
              "// Log metrics\r",
              "console.log(\"Current Time:\", currentTime);\r",
              "\r",
              "console.log(\"Minimum Time:\", minTime);\r",
              "\r",
              "console.log(\"Maximum Time:\", maxTime);\r",
              "\r",
              "console.log(\"Average Time:\", avgTime.toFixed(2));"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
